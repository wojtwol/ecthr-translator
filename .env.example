# ECTHR Translator Configuration

# Application Settings
APP_NAME="ECTHR Translator"
DEBUG=False

# HUDOC (European Court of Human Rights) Settings
HUDOC_BASE_URL=https://hudoc.echr.coe.int
HUDOC_ENABLED=True
HUDOC_MAX_RETRIES=3
HUDOC_TIMEOUT_SECONDS=30
# Set to True to use mock data instead of real API calls
HUDOC_USE_MOCK=False

# CURIA (Court of Justice of the European Union) Settings via EUR-Lex
EURLEX_SPARQL_ENDPOINT=https://publications.europa.eu/webapi/rdf/sparql
CURIA_ENABLED=True
CURIA_MAX_RETRIES=3
CURIA_TIMEOUT_SECONDS=30
# Set to True to use mock data instead of real API calls
CURIA_USE_MOCK=False

# IATE (Interactive Terminology for Europe) Settings
IATE_API_URL=https://iate.europa.eu/api
IATE_ENABLED=True
IATE_MAX_RETRIES=3
IATE_TIMEOUT_SECONDS=30
# Set to True to use mock data instead of real API calls
IATE_USE_MOCK=True
# API Credentials (contact iate@cdt.europa.eu to obtain)
# IATE_USERNAME=your_username_here
# IATE_API_KEY=your_api_key_here

# General API Settings
MAX_CONCURRENT_REQUESTS=5
CACHE_TTL_SECONDS=3600
