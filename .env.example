# Anthropic API Configuration
ANTHROPIC_API_KEY=sk-ant-...

# Paths
TM_PATH=./data/tm
UPLOAD_PATH=./data/uploads
OUTPUT_PATH=./data/outputs

# Database
DATABASE_URL=sqlite:///./data/ecthr.db

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO

# Frontend Configuration
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8000

# External Services
HUDOC_BASE_URL=https://hudoc.echr.coe.int
CURIA_BASE_URL=https://curia.europa.eu
HUDOC_ENABLED=true
CURIA_ENABLED=true

# TM Configuration
TM_FUZZY_THRESHOLD=0.75
TM_MAX_RESULTS=10

# Translation Configuration
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.docx
DEFAULT_LANGUAGE_PAIR=EN-PL

# Retry Configuration
HUDOC_MAX_RETRIES=3
HUDOC_TIMEOUT_SECONDS=30
CURIA_MAX_RETRIES=3
CURIA_TIMEOUT_SECONDS=30
CLAUDE_MAX_RETRIES=5
CLAUDE_TIMEOUT_SECONDS=120
